{
    "name": "@mohasinac/security",
    "version": "1.4.0",
    "type": "module",
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "description": "CSP helpers, rate limiter, and authorization guards",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./csp": {
            "types": "./dist/csp.d.ts",
            "import": "./dist/csp.js",
            "require": "./dist/csp.cjs"
        },
        "./pii-redact": {
            "types": "./dist/pii-redact.d.ts",
            "import": "./dist/pii-redact.js",
            "require": "./dist/pii-redact.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts src/csp.ts src/pii-redact.ts --format esm,cjs --dts",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@mohasinac/errors": "^1.4.0"
    },
    "peerDependencies": {
        "next": ">=14.0.0"
    },
    "peerDependenciesMeta": {
        "@upstash/redis": {
            "optional": true
        },
        "@upstash/ratelimit": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "next": "15.3.3",
        "tsup": "^8.5.0",
        "typescript": "^5.9.3"
    }
}
