{
  "name": "@mohasinac/payment-razorpay",
  "version": "0.1.0",
  "private": false,
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mohasinac/contracts": "^1.0.0",
    "@mohasinac/errors": "^1.0.0"
  },
  "peerDependencies": {
    "razorpay": ">=2.9.0"
  },
  "devDependencies": {
    "razorpay": "^2.9.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
