{
    "name": "@mohasinac/css-vanilla",
    "version": "1.4.0",
    "description": "Plain CSS custom properties adapter implementing IStyleAdapter from @mohasinac/contracts",
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts",
        "lint": "eslint src"
    },
    "devDependencies": {
        "tsup": "^8.5.0",
        "typescript": "^5.9.3",
        "eslint": "^9.37.0"
    },
    "peerDependencies": {
        "@mohasinac/contracts": "^1.4.0"
    }
}
