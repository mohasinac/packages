{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "composite": false,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist/types",
    "rootDir": "./src",
    "paths": {
      "@mohasinac/auth-firebase": ["../../packages/auth-firebase/src"],
      "@mohasinac/auth-firebase/*": ["../../packages/auth-firebase/src/*"],
      "@mohasinac/cli": ["../../packages/cli/src"],
      "@mohasinac/cli/*": ["../../packages/cli/src/*"],
      "@mohasinac/contracts": ["../../packages/contracts/src"],
      "@mohasinac/contracts/*": ["../../packages/contracts/src/*"],
      "@mohasinac/core": ["../../packages/core/src"],
      "@mohasinac/core/*": ["../../packages/core/src/*"],
      "@mohasinac/css-tailwind": ["../../packages/css-tailwind/src"],
      "@mohasinac/css-tailwind/*": ["../../packages/css-tailwind/src/*"],
      "@mohasinac/css-vanilla": ["../../packages/css-vanilla/src"],
      "@mohasinac/css-vanilla/*": ["../../packages/css-vanilla/src/*"],
      "@mohasinac/db-firebase": ["../../packages/db-firebase/src"],
      "@mohasinac/db-firebase/*": ["../../packages/db-firebase/src/*"],
      "@mohasinac/email-resend": ["../../packages/email-resend/src"],
      "@mohasinac/email-resend/*": ["../../packages/email-resend/src/*"],
      "@mohasinac/errors": ["../../packages/errors/src"],
      "@mohasinac/errors/*": ["../../packages/errors/src/*"],
      "@mohasinac/feat-collections": ["../../packages/feat-collections/src"],
      "@mohasinac/feat-collections/*": [
        "../../packages/feat-collections/src/*"
      ],
      "@mohasinac/feat-loyalty": ["../../packages/feat-loyalty/src"],
      "@mohasinac/feat-loyalty/*": ["../../packages/feat-loyalty/src/*"],
      "@mohasinac/feat-preorders": ["../../packages/feat-preorders/src"],
      "@mohasinac/feat-preorders/*": ["../../packages/feat-preorders/src/*"],
      "@mohasinac/feat-whatsapp-bot": ["../../packages/feat-whatsapp-bot/src"],
      "@mohasinac/feat-whatsapp-bot/*": [
        "../../packages/feat-whatsapp-bot/src/*"
      ],
      "@mohasinac/http": ["../../packages/http/src"],
      "@mohasinac/http/*": ["../../packages/http/src/*"],
      "@mohasinac/monitoring": ["../../packages/monitoring/src"],
      "@mohasinac/monitoring/*": ["../../packages/monitoring/src/*"],
      "@mohasinac/next": ["../../packages/next/src"],
      "@mohasinac/next/*": ["../../packages/next/src/*"],
      "@mohasinac/react": ["../../packages/react/src"],
      "@mohasinac/react/*": ["../../packages/react/src/*"],
      "@mohasinac/security": ["../../packages/security/src"],
      "@mohasinac/security/*": ["../../packages/security/src/*"],
      "@mohasinac/seo": ["../../packages/seo/src"],
      "@mohasinac/seo/*": ["../../packages/seo/src/*"],
      "@mohasinac/storage-firebase": ["../../packages/storage-firebase/src"],
      "@mohasinac/storage-firebase/*": [
        "../../packages/storage-firebase/src/*"
      ],
      "@mohasinac/tokens": ["../../packages/tokens/src"],
      "@mohasinac/tokens/*": ["../../packages/tokens/src/*"],
      "@mohasinac/ui": ["../../packages/ui/src"],
      "@mohasinac/ui/*": ["../../packages/ui/src/*"],
      "@mohasinac/utils": ["../../packages/utils/src"],
      "@mohasinac/utils/*": ["../../packages/utils/src/*"],
      "@mohasinac/validation": ["../../packages/validation/src"],
      "@mohasinac/validation/*": ["../../packages/validation/src/*"]
    }
  },
  "include": ["src", "manifest.ts"],
  "exclude": ["node_modules", "dist"]
}
