{
    "name": "@mohasinac/feat-whatsapp-bot",
    "version": "0.1.0",
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0",
        "next": ">=14.0.0"
    },
    "dependencies": {
        "@mohasinac/contracts": "^0.1.0"
    },
    "devDependencies": {
        "tsup": "^8.5.1",
        "typescript": "^5.4.5"
    }
}