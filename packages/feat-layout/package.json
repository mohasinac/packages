{
    "name":  "@mohasinac/feat-layout",
    "version":  "1.3.1",
    "type":  "module",
    "private":  false,
    "publishConfig":  {
                          "access":  "public"
                      },
    "description":  "Generic layout shell components: NavbarLayout, FooterLayout, SidebarLayout, BottomNavLayout, TitleBarLayout, Breadcrumbs, LocaleSwitcher",
    "main":  "./dist/index.cjs",
    "module":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js",
                              "require":  "./dist/index.cjs"
                          }
                },
    "files":  [
                  "dist"
              ],
    "scripts":  {
                    "build":  "tsup src/index.ts --format esm,cjs --dts --external @mohasinac/contracts",
                    "dev":  "tsup --watch",
                    "typecheck":  "tsc --noEmit"
                },
    "peerDependencies":  {
                             "@mohasinac/contracts":  "^1.3.0",
                             "react":  "\u003e=18.0.0",
                             "react-dom":  "\u003e=18.0.0",
                             "next":  "\u003e=14.0.0",
                             "next-intl":  "\u003e=3.0.0",
                             "lucide-react":  "\u003e=0.400.0"
                         },
    "devDependencies":  {
                            "@types/node":  "^22.0.0",
                            "@types/react":  "^19.0.0",
                            "@types/react-dom":  "^19.0.0",
                            "tsup":  "^8.5.0",
                            "typescript":  "^5.9.3"
                        }
}
