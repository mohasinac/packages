{
  "name": "@mohasinac/storage-firebase",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Firebase Storage (Admin SDK) implementation of @mohasinac/contracts IStorageProvider",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mohasinac/contracts": "^1.0.0",
    "@mohasinac/db-firebase": "^1.0.0"
  },
  "peerDependencies": {
    "firebase-admin": ">=12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "firebase-admin": "^13.6.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
