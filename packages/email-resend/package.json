{
  "name": "@mohasinac/email-resend",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Resend implementation of @mohasinac/contracts IEmailProvider",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mohasinac/contracts": "^0.1.0"
  },
  "peerDependencies": {
    "resend": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "resend": "^6.9.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
