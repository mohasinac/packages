{
    "name": "@mohasinac/feat-homepage",
    "version": "1.4.2",
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.js",
            "require": "./dist/server.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts src/server.ts --format esm,cjs --dts --external @mohasinac/contracts",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0",
        "next": ">=14.0.0",
        "next-intl": ">=3.0.0",
        "@tanstack/react-query": ">=5.0.0",
        "@mohasinac/react": "^1.4.0",
        "@mohasinac/ui": "^1.4.0",
        "@mohasinac/feat-media": "^1.4.0",
        "@mohasinac/tokens": "^1.4.0"
    },
    "dependencies": {
        "@mohasinac/contracts": "^1.4.0",
        "@mohasinac/next": "^1.4.0"
    },
    "devDependencies": {
        "@types/react": "^19.1.6",
        "@types/react-dom": "^19.1.6",
        "tsup": "^8.5.0",
        "typescript": "^5.9.3"
    }
}
